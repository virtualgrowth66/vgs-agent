# SiteMind AI Server — Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# OpenAI API (optional — server falls back to rule-based engine when not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=*

# ── Calendar Integration (at least one required for bookings) ──

# Calendar timezone
CALENDAR_TIMEZONE=America/New_York
# Default appointment duration in minutes
CALENDAR_DEFAULT_DURATION=60

# Option 1: Google Calendar (service account)
# 1. Go to https://console.cloud.google.com/ → Enable Calendar API
# 2. Create a service account, download JSON key
# 3. Share your calendar with the service account email
# 4. Set GOOGLE_CALENDAR_ID to your calendar email (e.g., yourname@gmail.com)
# 5. Set GOOGLE_SERVICE_ACCOUNT_JSON to the JSON key content OR path

# GOOGLE_CALENDAR_ID=yourname@gmail.com
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Option 2: Outlook Calendar (Microsoft Graph API)
# 1. Go to https://portal.azure.com/ → App registrations
# 2. Create a new app, add Calendar.ReadWrite API permission
# 3. Create a client secret
# 4. Set tenant ID (or "common" for multi-tenant)

# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_TENANT_ID=common
# OUTLOOK_CALENDAR_ID=me/calendar

# Option 3: Calendly (scheduling link — availability checking not supported)
# Visitors are redirected to your Calendly link to pick a time

# CALENDLY_LINK=https://calendly.com/yourname/30min
# CALENDLY_API_TOKEN=  # Optional, for listing event types
# CALENDLY_EVENT_TYPE=  # Optional event type URI

# ── Email Notifications ──

# Email provider: 'gmail' | 'outlook' | 'smtp' | 'dev'
EMAIL_PROVIDER=dev

# Business owner's email (receives lead notifications + booking confirmations)
NOTIFICATION_EMAIL=owner@example.com

# Sender details
EMAIL_SENDER_NAME=SiteMind AI
EMAIL_SENDER_EMAIL=noreply@sitemind.ai

# Option 1: Gmail (requires App Password)
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use that password here (not your regular Gmail password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option 2: Outlook / Office 365
OUTLOOK_EMAIL_USER=
OUTLOOK_EMAIL_PASS=

# Option 3: Custom SMTP (SendGrid, Mailgun, Postmark, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Follow-up email settings
EMAIL_FOLLOW_UP_ENABLED=true
EMAIL_FOLLOW_UP_HOURS=24
EMAIL_REMINDER_BEFORE_HOURS=2

# Business info (used in email signatures)
BUSINESS_NAME=SiteMind
BUSINESS_ADDRESS=
BUSINESS_PHONE=
BUSINESS_WEBSITE=